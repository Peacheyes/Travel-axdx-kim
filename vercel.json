{
  "rewrites": [
    {
      "source": "/api/tour/:path*",
      "destination": "https://apis.data.go.kr/:path*"
    },
    {
      "source": "/api/nominatim/:path*",
      "destination": "https://nominatim.openstreetmap.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
